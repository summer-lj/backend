NODE_ENV=test
APP_NAME=backend-starter-test
APP_HOST=127.0.0.1
PORT=3000
API_PREFIX=api/v1
LOG_LEVEL=warn
TRUST_PROXY=false
SWAGGER_ENABLED=false
CORS_ORIGINS=http://localhost:3000

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=backend_test
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/backend_test?schema=public

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/1

JWT_ACCESS_SECRET=test-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=test-refresh-secret
JWT_REFRESH_TTL=7d

DEFAULT_ADMIN_EMAIL=test-admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_NAME=Test Admin

AUTO_MIGRATE=false
AUTO_SEED=false
