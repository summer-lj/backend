NODE_ENV=development
APP_NAME=backend-starter
APP_HOST=0.0.0.0
PORT=3000
API_PREFIX=api/v1
LOG_LEVEL=debug
TRUST_PROXY=false
SWAGGER_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=backend_local
DATABASE_USER=backend
DATABASE_PASSWORD=backend
DATABASE_URL=postgresql://backend:backend@postgres:5432/backend_local?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

JWT_ACCESS_SECRET=change-this-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_REFRESH_TTL=7d

DEFAULT_ADMIN_EMAIL=founder@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_NAME=Founder Admin

AUTO_MIGRATE=true
AUTO_SEED=true
